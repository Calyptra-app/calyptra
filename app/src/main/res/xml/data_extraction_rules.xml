<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <include domain="root" />
        <include domain="file" />
        <include domain="database" />
        <include domain="sharedpref" />
        <include domain="external" />
        <!-- Never transfer the parental PIN material (PBKDF2 hash + salt) stored
             by the "settings" DataStore Preferences file. allowBackup="false"
             already blocks cloud backup, but device-to-device transfer on
             Android 12+ is not fully gated by allowBackup, so exclude it here
             explicitly as defense-in-depth. -->
        <exclude domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
