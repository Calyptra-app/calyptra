<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <include domain="sharedpref" path="."/>
    <include domain="database" path="."/>
    <!-- Legacy fullBackupContent (used pre-Android 12). Moot now that
         allowBackup="false". Only sharedpref + database are included, so the
         "file" domain — which holds the parental PIN material in the "settings"
         DataStore (datastore/settings.preferences_pb) — is never backed up.
         No explicit <exclude> for it: lint's FullBackupContent check rejects
         excluding a path that isn't inside an included domain. The device-
         transfer exclude in data_extraction_rules.xml still covers Android 12+. -->
</full-backup-content>
